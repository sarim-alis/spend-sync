generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id        Int      @id @default(autoincrement())
  name      String
  email     String   @unique
  password  String   
  incomes   Income[]
  expenses  Expense[]
  savings   Saving[]
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt 
}

model Income {
  id        Int      @id @default(autoincrement())
  amount    Float
  source    String?   // e.g. "Salary", "Freelance"
  user      User     @relation(fields: [userId], references: [id])
  userId    Int
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// Expense model
model Expense {
  id        Int      @id @default(autoincrement())
  amount    Float
  category  String?   // e.g. "Food", "Rent"
  user      User     @relation(fields: [userId], references: [id])
  userId    Int
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Saving {
  id        Int      @id @default(autoincrement())
  amount    Float
  goal      String?   // e.g. "Emergency Fund", "Travel"
  user      User     @relation(fields: [userId], references: [id])
  userId    Int
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}
